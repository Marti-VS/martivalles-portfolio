---
import { content } from '../data/content';
const { profile } = content;
const year = new Date().getFullYear();
---

<footer class="relative mx-auto px-5 sm:px-8 pt-10 pb-16 max-w-7xl">
  <div
    data-reveal
    class="bg-gradient-to-br from-[var(--color-space-2)] to-[var(--color-void)] p-8 sm:p-12 border border-white/10 rounded-3xl overflow-hidden"
  >
    <div class="flex md:flex-row flex-col justify-between items-start md:items-center gap-8">
      <div>
        <h2 class="font-display font-bold text-3xl sm:text-4xl">
          ¿Hablamos?
        </h2>
        <p class="mt-3 max-w-md text-[var(--color-stardust)]">
          Siempre abierto a nuevos proyectos, colaboraciones o simplemente a
          charlar sobre montañas y código.
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a
          href={`mailto:${profile.email}`}
          class="bg-gradient-to-r from-[var(--color-nebula)] to-[var(--color-magenta)] shadow-[0_0_30px_-6px_rgba(139,92,246,0.8)] px-6 py-3 rounded-full font-semibold text-white hover:scale-[1.04] transition-transform"
        >
          {profile.email}
        </a>
        <a
          href={profile.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="hover:bg-white/5 px-6 py-3 border border-white/15 rounded-full font-semibold text-white transition-colors"
        >
          LinkedIn
        </a>
        {
          profile.github && (
            <a
              href={profile.github}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:bg-white/5 px-6 py-3 border border-white/15 rounded-full font-semibold text-white transition-colors"
            >
              GitHub
            </a>
          )
        }
      </div>
    </div>
  </div>

  <div class="flex sm:flex-row flex-col justify-between items-center gap-3 mt-8 text-[var(--color-muted)] text-sm">
    <p>© {year} {profile.name}. Hecho con Astro, Three.js y amor.</p>
    <a href="/universo" data-warp class="hover:text-white transition-colors">
      Entrar al universo →
    </a>
  </div>
</footer>
