---
/**
 * Objetos que cruzan el cielo de vez en cuando (uno cada vez, a intervalos
 * aleatorios). Reparto de probabilidad: cometa 70%, satélite 20%, ovni 10%.
 * Son puramente decorativos y se pintan detrás del contenido.
 */
---

<div id="sky-objects" class="pointer-events-none fixed inset-0 -z-[15] overflow-hidden" aria-hidden="true"></div>

<style is:global>
  #sky-objects .sky-obj {
    position: fixed;
    top: 0;
    left: 0;
    will-change: transform, opacity;
  }
  #sky-objects .sky-obj svg {
    display: block;
  }
  #sky-objects .glow-comet {
    filter: drop-shadow(0 0 3px rgba(56, 232, 255, 0.45));
  }
  #sky-objects .glow-sat {
    filter: drop-shadow(0 0 2px rgba(169, 240, 255, 0.35));
  }
  #sky-objects .glow-ufo {
    filter: drop-shadow(0 0 4px rgba(139, 92, 246, 0.5));
  }
  #sky-objects .ufo-inner {
    display: block;
    animation: ufo-bob 1.9s ease-in-out infinite;
  }
  @keyframes ufo-bob {
    0%,
    100% {
      transform: translateY(0) rotate(-2.5deg);
    }
    50% {
      transform: translateY(-4px) rotate(2.5deg);
    }
  }
  #sky-objects .sat-inner {
    display: block;
    animation: sat-sway 6.5s ease-in-out infinite;
  }
  @keyframes sat-sway {
    0%,
    100% {
      transform: rotate(-11deg);
    }
    50% {
      transform: rotate(11deg);
    }
  }
</style>

<script>
  const container = document.getElementById('sky-objects');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (container && !reduce) {
    let uid = 0;

    const comet = (u: number) => `
      <svg width="94" height="29" viewBox="0 0 150 46" class="glow-comet">
        <defs>
          <linearGradient id="ct${u}" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0" stop-color="#38e8ff" stop-opacity="0"/>
            <stop offset="0.65" stop-color="#7dd3fc" stop-opacity="0.45"/>
            <stop offset="1" stop-color="#e6faff" stop-opacity="0.95"/>
          </linearGradient>
          <radialGradient id="ch${u}" cx="0.5" cy="0.5" r="0.5">
            <stop offset="0" stop-color="#ffffff"/>
            <stop offset="0.5" stop-color="#a9f0ff"/>
            <stop offset="1" stop-color="#38e8ff" stop-opacity="0.15"/>
          </radialGradient>
        </defs>
        <path d="M8 23 L124 16 L124 30 Z" fill="url(#ct${u})"/>
        <circle cx="128" cy="23" r="8.5" fill="url(#ch${u})"/>
      </svg>`;

    const satellite = () => `
      <span class="sat-inner">
        <svg width="50" height="25" viewBox="0 0 80 40" class="glow-sat">
          <g stroke="#a9f0ff" stroke-width="0.75">
            <rect x="3" y="15" width="23" height="11" rx="1.5" fill="#1e6f6a"/>
            <rect x="54" y="15" width="23" height="11" rx="1.5" fill="#1e6f6a"/>
            <line x1="14.5" y1="15" x2="14.5" y2="26"/>
            <line x1="65.5" y1="15" x2="65.5" y2="26"/>
            <rect x="31" y="12" width="18" height="17" rx="2.5" fill="#cdd6ff"/>
            <line x1="40" y1="12" x2="40" y2="4"/>
          </g>
          <circle cx="40" cy="3.5" r="2" fill="#38e8ff"/>
        </svg>
      </span>`;

    const ufo = () => `
      <span class="ufo-inner">
        <svg width="56" height="32" viewBox="0 0 92 52" class="glow-ufo">
          <ellipse cx="46" cy="36" rx="40" ry="10" fill="#4c1d95"/>
          <ellipse cx="46" cy="33" rx="40" ry="9" fill="#7c3aed"/>
          <ellipse cx="46" cy="23" rx="19" ry="15" fill="#bfe9ff" opacity="0.9"/>
          <ellipse cx="46" cy="21" rx="10" ry="7" fill="#eafaff"/>
          <circle cx="20" cy="35" r="2.3" fill="#38e8ff"/>
          <circle cx="35" cy="37" r="2.3" fill="#e853c9"/>
          <circle cx="46" cy="38" r="2.3" fill="#ffd479"/>
          <circle cx="57" cy="37" r="2.3" fill="#38e8ff"/>
          <circle cx="72" cy="35" r="2.3" fill="#e853c9"/>
        </svg>
      </span>`;

    /** Elige tipo según probabilidad: cometa 70%, satélite 20%, ovni 10%. */
    function pickKind() {
      const r = Math.random() * 100;
      if (r < 70) return 'comet';
      if (r < 90) return 'satellite';
      return 'ufo';
    }

    function spawn() {
      // Como mucho unos pocos a la vez (evita acumulaciones raras).
      if (container!.childElementCount > 3) return;

      const kind = pickKind();
      const el = document.createElement('div');
      el.className = 'sky-obj';
      el.innerHTML =
        kind === 'comet' ? comet(uid++) : kind === 'satellite' ? satellite() : ufo();
      container!.appendChild(el);

      const vw = window.innerWidth;
      const vh = window.innerHeight;
      const dir = Math.random() < 0.5 ? 1 : -1; // 1: izq→der · -1: der→izq
      const margin = 180;

      const yStart = vh * (0.05 + Math.random() * 0.55);
      const driftMap: Record<string, number> = { comet: 0.22, satellite: 0.05, ufo: 0.12 };
      const yEnd = yStart + (Math.random() - 0.5) * vh * driftMap[kind];

      const xStart = dir === 1 ? -margin : vw + margin;
      // El cometa NO cruza toda la pantalla: recorre un tramo (38–62% del ancho)
      // y se apaga. Satélite y ovni sí cruzan de lado a lado.
      const isComet = kind === 'comet';
      const xEnd = isComet
        ? xStart + dir * vw * (0.38 + Math.random() * 0.24)
        : dir === 1
          ? vw + margin
          : -margin;

      // El cometa apunta hacia su dirección de movimiento.
      const rot = isComet
        ? (Math.atan2(yEnd - yStart, xEnd - xStart) * 180) / Math.PI
        : 0;

      const durMap: Record<string, number> = { comet: 2800, satellite: 11000, ufo: 4400 };
      const duration = durMap[kind] * (0.85 + Math.random() * 0.3);

      // Opacidad máxima baja: son detalles sutiles de fondo, no protagonistas.
      const peakMap: Record<string, number> = { comet: 0.5, satellite: 0.4, ufo: 0.5 };
      const peak = peakMap[kind];

      // Cometa: aparece, avanza y se desvanece poco a poco (fundido largo) mientras
      // frena. Los demás: cruzan con un fundido de entrada/salida normal.
      const keyframes = isComet
        ? [
            { transform: `translate(${xStart}px, ${yStart}px) rotate(${rot}deg)`, opacity: 0 },
            { opacity: peak, offset: 0.16 },
            { opacity: peak, offset: 0.42 },
            { transform: `translate(${xEnd}px, ${yEnd}px) rotate(${rot}deg)`, opacity: 0, offset: 1 },
          ]
        : [
            { transform: `translate(${xStart}px, ${yStart}px) rotate(${rot}deg)`, opacity: 0 },
            { opacity: peak, offset: 0.15 },
            { opacity: peak, offset: 0.85 },
            { transform: `translate(${xEnd}px, ${yEnd}px) rotate(${rot}deg)`, opacity: 0 },
          ];

      const anim = el.animate(keyframes, {
        duration,
        easing: isComet ? 'cubic-bezier(0.22, 0.61, 0.36, 1)' : 'linear',
      });
      const cleanup = () => el.remove();
      anim.onfinish = cleanup;
      anim.oncancel = cleanup;
    }

    // Aparecen de vez en cuando: intervalos aleatorios de ~8–22 s.
    function scheduleNext() {
      const delay = 8000 + Math.random() * 14000;
      window.setTimeout(() => {
        if (document.visibilityState === 'visible') spawn();
        scheduleNext();
      }, delay);
    }

    // Primer objeto un poco antes, para que se note que "hay vida".
    window.setTimeout(() => {
      if (document.visibilityState === 'visible') spawn();
      scheduleNext();
    }, 4000 + Math.random() * 4000);
  }
</script>
