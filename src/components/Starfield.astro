---
/**
 * Fondo de estrellas 2D para la landing. Estrellas fijas (sin parallax de
 * ratón) con un leve twinkle. Nebulosa oscura y sutil detrás.
 * Respeta prefers-reduced-motion.
 */
---

<canvas id="starfield" class="pointer-events-none fixed inset-0 -z-10 h-full w-full"></canvas>

<div
  class="pointer-events-none fixed inset-0 -z-[20]"
  style="background:
    radial-gradient(1100px 780px at 80% 8%, rgba(139,92,246,0.16), transparent 60%),
    radial-gradient(900px 680px at 8% 20%, rgba(56,232,255,0.10), transparent 60%),
    radial-gradient(960px 720px at 88% 88%, rgba(232,83,201,0.12), transparent 62%),
    radial-gradient(820px 700px at 15% 96%, rgba(45,212,191,0.08), transparent 60%),
    linear-gradient(180deg, #04050f 0%, #05061a 55%, #04050d 100%);"
>
</div>

<script>
  const canvas = document.getElementById('starfield') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let w = 0;
    let h = 0;
    let dpr = Math.min(window.devicePixelRatio || 1, 2);

    type Star = {
      x: number;
      y: number;
      z: number;
      r: number;
      tw: number;
      ph: number;
      col: string;
    };
    let stars: Star[] = [];

    const COLORS = ['#ffffff', '#cdd6ff', '#bfa9ff', '#a9f0ff'];

    function build() {
      w = canvas!.clientWidth;
      h = canvas!.clientHeight;
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas!.width = Math.floor(w * dpr);
      canvas!.height = Math.floor(h * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      const count = Math.min(340, Math.floor((w * h) / 6500));
      stars = Array.from({ length: count }, () => ({
        x: Math.random() * w,
        y: Math.random() * h,
        z: Math.random() * 0.9 + 0.1,
        r: Math.random() * 1.4 + 0.3,
        tw: Math.random() * 0.6 + 0.2,
        ph: Math.random() * Math.PI * 2,
        col: COLORS[Math.floor(Math.random() * COLORS.length)],
      }));
    }

    // Las estrellas NO se mueven: sólo un leve parpadeo de brillo.
    let t = 0;
    function frame() {
      t += 0.016;
      ctx.clearRect(0, 0, w, h);
      for (const s of stars) {
        const a = reduce ? 0.85 : 0.5 + 0.4 * Math.sin(t * s.tw + s.ph);
        ctx.globalAlpha = Math.max(0.08, a) * (0.4 + s.z * 0.6);
        ctx.fillStyle = s.col;
        ctx.beginPath();
        ctx.arc(s.x, s.y, s.r * (0.6 + s.z), 0, Math.PI * 2);
        ctx.fill();
      }
      ctx.globalAlpha = 1;
      if (!reduce) requestAnimationFrame(frame);
    }

    build();
    window.addEventListener('resize', build);
    if (reduce) {
      frame();
    } else {
      requestAnimationFrame(frame);
    }
  }
</script>
