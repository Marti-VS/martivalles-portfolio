---
/**
 * Fondo de estrellas 2D para la landing. Canvas ligero con parallax suave
 * al mover el ratón y twinkle. Respeta prefers-reduced-motion.
 */
---

<canvas id="starfield" class="pointer-events-none fixed inset-0 -z-10 h-full w-full"></canvas>

<div
  class="nebula-bg pointer-events-none fixed inset-0 -z-10"
  style="background:
    radial-gradient(1150px 760px at 72% -8%, rgba(139,92,246,0.30), transparent 60%),
    radial-gradient(1000px 680px at 6% 6%, rgba(56,232,255,0.18), transparent 60%),
    radial-gradient(920px 640px at 92% 84%, rgba(232,83,201,0.22), transparent 62%),
    radial-gradient(760px 600px at 16% 104%, rgba(45,212,191,0.16), transparent 60%),
    radial-gradient(680px 560px at 50% 42%, rgba(109,40,217,0.16), transparent 66%),
    linear-gradient(180deg, #05061a 0%, #080b22 52%, #05061a 100%);"
>
</div>

<style>
  /* Deriva muy lenta de la nebulosa para que el fondo respire.
     El scale base evita que se vean bordes al desplazarse. */
  .nebula-bg {
    animation: nebula-drift 34s ease-in-out infinite;
    will-change: transform;
  }
  @keyframes nebula-drift {
    0%,
    100% {
      transform: translate3d(0, 0, 0) scale(1.08);
    }
    50% {
      transform: translate3d(-2%, 1.6%, 0) scale(1.13);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .nebula-bg {
      animation: none;
      transform: scale(1.08);
    }
  }
</style>

<script>
  const canvas = document.getElementById('starfield') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let w = 0;
    let h = 0;
    let dpr = Math.min(window.devicePixelRatio || 1, 2);

    type Star = { x: number; y: number; z: number; r: number; tw: number; ph: number };
    let stars: Star[] = [];

    const COLORS = ['#ffffff', '#cdd6ff', '#bfa9ff', '#a9f0ff'];

    function build() {
      w = canvas!.clientWidth;
      h = canvas!.clientHeight;
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas!.width = Math.floor(w * dpr);
      canvas!.height = Math.floor(h * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      const count = Math.min(360, Math.floor((w * h) / 6000));
      stars = Array.from({ length: count }, () => ({
        x: Math.random() * w,
        y: Math.random() * h,
        z: Math.random() * 0.9 + 0.1,
        r: Math.random() * 1.4 + 0.3,
        tw: Math.random() * 0.6 + 0.2,
        ph: Math.random() * Math.PI * 2,
      }));
    }

    let mx = 0;
    let my = 0;
    let tx = 0;
    let ty = 0;
    window.addEventListener('mousemove', (e) => {
      tx = (e.clientX / w - 0.5) * 2;
      ty = (e.clientY / h - 0.5) * 2;
    });

    let t = 0;
    function frame() {
      t += 0.016;
      mx += (tx - mx) * 0.05;
      my += (ty - my) * 0.05;
      ctx.clearRect(0, 0, w, h);
      for (let i = 0; i < stars.length; i++) {
        const s = stars[i];
        const px = s.x + mx * 26 * s.z;
        const py = s.y + my * 26 * s.z;
        const a = reduce ? 0.8 : 0.45 + 0.55 * Math.sin(t * s.tw + s.ph);
        ctx.globalAlpha = Math.max(0.05, a) * (0.4 + s.z * 0.6);
        ctx.fillStyle = COLORS[i % COLORS.length];
        ctx.beginPath();
        ctx.arc(px, py, s.r * (0.6 + s.z), 0, Math.PI * 2);
        ctx.fill();
      }
      ctx.globalAlpha = 1;
      if (!reduce) requestAnimationFrame(frame);
    }

    build();
    window.addEventListener('resize', build);
    if (reduce) {
      frame();
    } else {
      requestAnimationFrame(frame);
    }
  }
</script>
